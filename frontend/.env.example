# Backend REST API base URL (defaults to http://localhost:8080/api when unset).
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# Supabase Auth (Google login). Dashboard -> Settings -> API:
# Project URL + anon/publishable key. The Google button is hidden behind an
# error message when these are unset.
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
