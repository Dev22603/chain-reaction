PORT=8080
# All data storage lives in Supabase Postgres. Get both URLs from
# Supabase Dashboard -> Connect (top bar) -> "Transaction pooler" / "Session pooler".
#
# DATABASE_URL (required): transaction pooler, port 6543. Used by the app at runtime.
# sslmode=no-verify is required for node-postgres: Supabase serves a self-signed CA
# that pg cannot verify, and pg treats sslmode=require as full verification.
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-1-[REGION].pooler.supabase.com:6543/postgres?sslmode=no-verify
# DIRECT_URL: session pooler, port 5432. Used only by the Prisma CLI
# (db:migrate, db:studio, db:seed) which needs session-mode Postgres features.
DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres?sslmode=require
# For a local Postgres instead, set DATABASE_URL to it and leave DIRECT_URL unset:
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/chain_reaction

# Supabase Auth (Google login only). From Dashboard -> Settings -> API:
# SUPABASE_URL is the Project URL; SUPABASE_ANON_KEY is the anon/publishable key.
# Leave both unset to disable Google login (POST /api/auth/google returns 503).
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=
# JWT_SECRET must be set to a strong random value (>= 32 characters) in production
JWT_SECRET=change-me-in-development
JWT_EXPIRES_IN=1d
JWT_ISSUER=chain-reaction-backend
JWT_AUDIENCE=chain-reaction-client
# ALLOWED_ORIGINS is a comma-separated list of CORS-allowed origins. Empty allows all.
ALLOWED_ORIGINS=https://your-frontend.example
# CLIENT_IP_HEADER specifies a custom header to trust for client IP resolution (optional, e.g. Fly-Client-IP, CF-Connecting-IP)
# CLIENT_IP_HEADER=Fly-Client-IP

# ANONYMIZE_LOGS controls whether logged client IP addresses are hashed/truncated. Defaults to false.
ANONYMIZE_LOGS=false
