{
  "include": ["src", "prisma", "prisma.config.ts"],
  "exclude": ["node_modules"],
  "compilerOptions": {
    "rootDir": "./",
    "outDir": "./dist",
    "target": "ES2022",
    "types": ["node"],
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext"
  }
}
